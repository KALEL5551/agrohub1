# SETUP (fixes "placeholder.supabase.co" and login/database errors)
# 1) Create a free project: https://supabase.com/dashboard
# 2) Project Settings → API → copy "Project URL" and "anon public" key into this file
# 3) Save as apps/web/.env.local (not .example) and restart: npm run dev
# 4) SQL: run your schema from supabase/migrations in the Supabase SQL editor (or supabase db push)
# 5) Google OAuth: Authentication → Providers → Google (enable; add Google Cloud OAuth client ID/secret)
#    Also add redirect URL in Supabase: Authentication → URL Configuration →
#    Redirect URLs: http://localhost:3000/api/auth/callback
#ANTHROPIC_API_KEY=your_key_here
# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL="key"
NEXT_PUBLIC_SUPABASE_ANON_KEY="key"
SUPABASE_SERVICE_ROLE_KEY="your key"

# ── Flutterwave ──
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxx
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxx
FLUTTERWAVE_SECRET_HASH=

# ── MTN MoMo ──
MTN_MOMO_SUBSCRIPTION_KEY=xxxxx
MTN_MOMO_API_USER=xxxxx
MTN_MOMO_API_KEY=xxxxx
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=https://yourdomain.com/api/payments/momo/callback

# ── DHL ──
DHL_API_KEY=xxxxx
DHL_API_SECRET=xxxxx
DHL_ACCOUNT_NUMBER=xxxxx

# ── Claude AI ──
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AgriTrade Africa
ADMIN_EMAILS=admin@agritrade.africa

# ── Notifications ──
ONESIGNAL_APP_ID=xxxxx
ONESIGNAL_API_KEY=xxxxx

# ── Commission ──
NEXT_PUBLIC_PLATFORM_COMMISSION_PERCENT=5
